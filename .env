# ─── Application ──────────────────────────────────────────────
NODE_ENV=development              # development | production
APP_DOMAIN=localhost                 # domain name for the app

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=NEXT_PUBLIC_API_URL=http://localhost:3000       # backend API base URL (via nginx)
NEXT_PUBLIC_WS_URL=ws://localhost:3000         # WebSocket URL (via nginx)
NEXT_PUBLIC_MEDIA_URL=http://localhost:3000/media   # media/upload base URL

# ─── Backend (NestJS) ────────────────────────────────────────
BACKEND_PORT=3000         # internal port for NestJS
JWT_SECRET=supersecretjwtkey1234567890abcdef             # JWT signing secret (random 64+ chars)
JWT_EXPIRATION=15m     # access token TTL (e.g. 15m)
JWT_REFRESH_EXPIRATION=7d # refresh token TTL (e.g. 7d)
CORS_ORIGIN=http://localhost:3000           # allowed CORS origin

# ─── OAuth2 (Google) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=put_your_google_client_id_here         # Google OAuth client ID
GOOGLE_CLIENT_SECRET=put_your_google_client_secret_here # Google OAuth client secret
GOOGLE_CALLBACK_URL=put_your_callback_url_here          # Google OAuth redirect URI

# ─── Two-Factor Authentication ───────────────────────────────
TOTP_APP_NAME=put_your_totp_app_name_here       # name shown in authenticator app

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=ft_postgres       # Docker service name (e.g. postgres)
POSTGRES_PORT=5432       # default PostgreSQL port (e.g. 5432)
POSTGRES_USER=transcendence       # database user
POSTGRES_PASSWORD=transcendence # database password
POSTGRES_DB=transcendence           # database name
DATABASE_URL=postgres://transcendence:transcendence@ft_postgres:5432/transcendence         # full connection string

# ─── Media Storage (Local) ───────────────────────────────────
UPLOAD_DIR=/app/uploads             # local directory for file uploads (e.g. /app/uploads)
MAX_FILE_SIZE=put_your_max_file_size_here       # max upload size in bytes (e.g. 10485760)

# ─── Nginx ────────────────────────────────────────────────────
NGINX_HTTPS_PORT=443       # external HTTPS port (e.g. 8443)
NGINX_HTTP_PORT=8080         # external HTTP port (e.g. 8080)

# ─── Monitoring ───────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=put_your_grafana_user_here       # Grafana admin username
GF_SECURITY_ADMIN_PASSWORD=put_your_grafana_password_here # Grafana admin password
GF_SERVER_ROOT_URL=put_your_grafana_root_url_here       # Grafana root URL

# ─── HashiCorp Vault ─────────────────────────────────────────
VAULT_ADDR=put_your_vault_address_here          # Vault server address (e.g. http://vault:8200)
VAULT_TOKEN=put_your_vault_root_token_here      # Vault root token (dev mode only)
VAULT_DEV_ROOT_TOKEN_ID=put_your_vault_dev_token_here   # Vault dev root token ID
