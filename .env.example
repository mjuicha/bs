# ─── Application ──────────────────────────────────────────────
NODE_ENV=put_your_environment_here              # development | production
APP_DOMAIN=put_your_domain_here                 # domain name for the app

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=put_your_api_url_here       # backend API base URL (via nginx)
NEXT_PUBLIC_WS_URL=put_your_ws_url_here         # WebSocket URL (via nginx)
NEXT_PUBLIC_MEDIA_URL=put_your_media_url_here   # media/upload base URL

# ─── Backend (NestJS) ────────────────────────────────────────
BACKEND_PORT=put_your_backend_port_here         # internal port for NestJS
JWT_SECRET=put_your_jwt_secret_here             # JWT signing secret (random 64+ chars)
JWT_EXPIRATION=put_your_jwt_expiration_here     # access token TTL (e.g. 15m)
JWT_REFRESH_EXPIRATION=put_your_refresh_ttl_here # refresh token TTL (e.g. 7d)
CORS_ORIGIN=put_your_cors_origin_here           # allowed CORS origin

# ─── OAuth2 (Google) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=put_your_google_client_id_here         # Google OAuth client ID
GOOGLE_CLIENT_SECRET=put_your_google_client_secret_here # Google OAuth client secret
GOOGLE_CALLBACK_URL=put_your_callback_url_here          # Google OAuth redirect URI

# ─── Two-Factor Authentication ───────────────────────────────
TOTP_APP_NAME=put_your_totp_app_name_here       # name shown in authenticator app

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=put_your_postgres_host_here       # Docker service name (e.g. postgres)
POSTGRES_PORT=put_your_postgres_port_here       # default PostgreSQL port (e.g. 5432)
POSTGRES_USER=put_your_postgres_user_here       # database user
POSTGRES_PASSWORD=put_your_postgres_password_here # database password
POSTGRES_DB=put_your_postgres_db_here           # database name
DATABASE_URL=put_your_database_url_here         # full connection string

# ─── Media Storage (Local) ───────────────────────────────────
UPLOAD_DIR=put_your_upload_dir_here             # local directory for file uploads (e.g. /app/uploads)
MAX_FILE_SIZE=put_your_max_file_size_here       # max upload size in bytes (e.g. 10485760)

# ─── Nginx ────────────────────────────────────────────────────
NGINX_HTTPS_PORT=put_your_https_port_here       # external HTTPS port (e.g. 8443)
NGINX_HTTP_PORT=put_your_http_port_here         # external HTTP port (e.g. 8080)

# ─── Monitoring ───────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=put_your_grafana_user_here       # Grafana admin username
GF_SECURITY_ADMIN_PASSWORD=put_your_grafana_password_here # Grafana admin password
GF_SERVER_ROOT_URL=put_your_grafana_root_url_here       # Grafana root URL

# ─── HashiCorp Vault ─────────────────────────────────────────
VAULT_ADDR=put_your_vault_address_here          # Vault server address (e.g. http://vault:8200)
VAULT_TOKEN=put_your_vault_root_token_here      # Vault root token (dev mode only)
VAULT_DEV_ROOT_TOKEN_ID=put_your_vault_dev_token_here   # Vault dev root token ID
