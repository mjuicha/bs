{
    "name": "ft-transcendence-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "nest build",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:prod": "node dist/main.js",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
        "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:generate": "npm run typeorm -- migration:generate -d src/config/data-source.ts",
        "migration:run": "npm run typeorm -- migration:run -d src/config/data-source.ts",
        "migration:revert": "npm run typeorm -- migration:revert -d src/config/data-source.ts"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/passport": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/platform-socket.io": "^11.0.0",
        "@nestjs/swagger": "^11.0.0",
        "@nestjs/throttler": "^6.3.0",
        "@nestjs/typeorm": "^11.0.0",
        "@nestjs/websockets": "^11.0.0",
        "bcrypt": "^5.1.0",
        "class-transformer": "^0.5.0",
        "class-validator": "^0.14.0",
        "google-auth-library": "^9.0.0",
        "otplib": "^12.0.1",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.0",
        "pg": "^8.13.0",
        "qrcode": "^1.5.4",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "typeorm": "^0.3.20"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@types/bcrypt": "^5.0.0",
        "@types/express": "^5.0.0",
        "@types/multer": "^2.1.0",
        "@types/node": "^22.0.0",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/passport-jwt": "^4.0.0",
        "@types/qrcode": "^1.5.6",
        "eslint": "^9.0.0",
        "source-map-support": "^0.5.0",
        "ts-node": "^10.9.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.0"
    }
}
